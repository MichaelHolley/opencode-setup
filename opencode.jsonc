{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@sveltejs/opencode"], // optional
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
  },
  "keybinds": {
    "session_child_cycle": "ctrl+e",
    "session_child_cycle_reverse": "ctrl+q",
  },
}
